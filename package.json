{
  "name": "harvics-localized-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8080",
    "backend": "tsx --tsconfig backend/tsconfig.json backend/src/index.ts",
    "backend:watch": "tsx watch --tsconfig backend/tsconfig.json backend/src/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next build && next export",
    "build:static": "next build && next export -o out",
    "build:netlify": "npm run build && echo 'Build complete! Upload the .next folder to Netlify.'",
    "clear-cache": "rm -rf .next && echo 'Cache cleared!'",
    "test-all": "./scripts/test-all.sh",
    "test": "./scripts/test-all.sh",
    "verify": "./scripts/test-all.sh",
    "start-servers": "./scripts/START_SERVERS.sh",
    "stop-servers": "./scripts/STOP_SERVERS.sh"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.7",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "axios": "^1.13.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "next": "^15.5.6",
    "next-intl": "^3.0.0",
    "postcss": "^8.4.47",
    "puppeteer": "^24.36.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.5.0",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/prop-types": "^15.7.15",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.7.1"
  },
  "keywords": [
    "corporate",
    "website",
    "harvics",
    "localization",
    "i18n"
  ],
  "author": "Harvics",
  "license": "ISC",
  "description": "Localized corporate website for Harvics - Dubai, UAE"
}