{
  "name": "harvics-localized-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8080",
    "backend": "tsx --tsconfig backend/tsconfig.json backend/src/index.ts",
    "backend:watch": "tsx watch --tsconfig backend/tsconfig.json backend/src/index.ts",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:start": "node backend/dist/index.js",
    "build": "next build",
    "build:prod": "npm run backend:build && npm run build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "next lint",
    "export": "next build && next export",
    "build:static": "next build && next export -o out",
    "build:netlify": "npm run build && echo 'Build complete! Upload the .next folder to Netlify.'",
    "clear-cache": "rm -rf .next && echo 'Cache cleared!'",
    "test-all": "./scripts/test-all.sh",
    "test": "./scripts/test-all.sh",
    "verify": "./scripts/test-all.sh",
    "start-servers": "./scripts/START_SERVERS.sh",
    "stop-servers": "./scripts/STOP_SERVERS.sh",
    "images:compress": "node scripts/compress-images.mjs",
    "images:bulk": "node scripts/compress-images.mjs --mode=bulk-copy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@cursor/sdk": "^1.0.18",
    "@huggingface/inference": "^4.13.18",
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/client": "^6.19.2",
    "@react-google-maps/api": "^2.20.7",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.4.20",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "framer-motion": "^12.40.0",
    "groq-sdk": "^1.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.24.0",
    "next": "^15.5.18",
    "next-intl": "^3.26.5",
    "postcss": "^8.4.47",
    "prisma": "^6.19.2",
    "puppeteer": "^24.36.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.5.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "undici": "^6.19.8",
    "wrangler": "^4.95.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/prop-types": "^15.7.15",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.7.1"
  },
  "keywords": [
    "corporate",
    "website",
    "harvics",
    "localization",
    "i18n"
  ],
  "author": "Harvics",
  "license": "ISC",
  "description": "Localized corporate website for Harvics - Dubai, UAE"
}
