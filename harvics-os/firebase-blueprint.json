{
  "entities": {
    "HsCode": {
      "title": "HS Code",
      "description": "Harmonized System code for product classification",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The 12-digit HS code" },
        "product": { "type": "string", "description": "Product description" },
        "duty": { "type": "string", "description": "Duty rate" },
        "status": { "type": "string", "enum": ["Green", "Review", "Red"], "description": "Compliance status" },
        "category": { "type": "string", "description": "Product category" },
        "documentId": { "type": "string", "description": "Reference to source document" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["code", "product", "status", "category", "authorUid", "createdAt"]
    },
    "Settlement": {
      "title": "Settlement",
      "description": "Trade finance settlement record",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Settlement type" },
        "name": { "type": "string", "description": "Entity name" },
        "amount": { "type": "string", "description": "Settlement amount" },
        "status": { "type": "string", "description": "Settlement status" },
        "color": { "type": "string", "description": "UI color class" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["type", "name", "amount", "status", "authorUid", "createdAt"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "System activity log entry",
      "type": "object",
      "properties": {
        "message": { "type": "string", "description": "Log message" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Log timestamp" },
        "userId": { "type": "string" }
      },
      "required": ["message", "timestamp", "userId"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Security and compliance audit log entry",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["ALERTS_FOUND", "APPROVED"] },
        "alerts": { "type": "array", "items": { "type": "object" } },
        "checkedShipments": { "type": "integer" },
        "checkedHsCodes": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["status", "timestamp", "userId"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "Logistics shipment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "route": { "type": "string" },
        "eta": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Green", "Review", "Red", "Correcting"] },
        "details": { "type": "string" },
        "isGoverned": { "type": "boolean" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "route", "status"]
    },
    "Stats": {
      "title": "Stats",
      "description": "Global system statistics",
      "type": "object",
      "properties": {
        "accuracy": { "type": "number" },
        "shipmentsCount": { "type": "integer" },
        "settledAmount": { "type": "number" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user-specific notification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error", "success"] },
        "read": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "userId", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "description": "Uploaded document metadata and OCR results",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "ocrData": { "type": "object" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "userId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/hs_codes": {
      "schema": "HsCode",
      "description": "Global HS code repository"
    },
    "/settlements": {
      "schema": "Settlement",
      "description": "Trade finance settlements"
    },
    "/activity_logs": {
      "schema": "ActivityLog",
      "description": "System-wide activity logs"
    },
    "/users": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/shipments": {
      "schema": "Shipment",
      "description": "Shipment tracking data"
    },
    "/stats": {
      "schema": "Stats",
      "description": "Global statistics"
    },
    "/notifications": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/documents": {
      "schema": "Document",
      "description": "Uploaded documents and OCR data"
    }
  }
}
