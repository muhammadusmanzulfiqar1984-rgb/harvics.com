# Vatify OS — Environment Variables
# Copy to .env.local and fill in values

# Required: Groq API key for AI features (receipt OCR, chat, categorization)
GROQ_API_KEY="your-groq-api-key"

# Optional: Hugging Face API key for image generation and translation
HF_API_KEY="your-hf-api-key"

# Optional: Server port (defaults to 5173)
PORT=5173

# Optional: Node environment
NODE_ENV=development
