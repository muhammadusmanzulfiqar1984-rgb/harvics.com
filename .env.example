# ─────────────────────────────────────────────────────────────────────────────
# HarvyX GTM OS — environment variable reference
# Harvics Global Ventures s.r.o., Prague
#
# Copy this file to .env (local) or .dev.vars (Cloudflare Workers local dev).
# Never commit real values. All secrets must be set via:
#   wrangler secret put <VAR_NAME>          (Cloudflare Worker secrets)
#   Vercel / Railway / Render env panel     (Node.js API + workers)
# ─────────────────────────────────────────────────────────────────────────────


# ── DATABASE ──────────────────────────────────────────────────────────────────

# Full Postgres connection string — used by every worker, repository, and the
# Cloudflare Hyperdrive binding. Format: postgresql://user:pass@host:5432/db
HX_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/harvyx


# ── REDIS / BULLMQ ────────────────────────────────────────────────────────────

# Redis connection URL consumed by all 6 BullMQ workers and the scrapers.
# TLS example: rediss://default:PASSWORD@HOST:6380
HX_REDIS_URL=redis://default:PASSWORD@HOST:6379


# ── API SERVER ────────────────────────────────────────────────────────────────

# Port the Express reporting API listens on. Defaults to 3001 if omitted.
HX_API_PORT=3001

# Public base URL of the Express API — consumed by the HxDataBankTab UI component.
# Production: https://api.harvics.com   Local: http://localhost:3001
HX_API_URL=http://localhost:3001

# HS256 secret used to sign and verify JWT tokens on every API route.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HX_JWT_SECRET=CHANGE_ME_256_BIT_HEX_STRING


# ── CLOUDFLARE R2 (S3-compatible) ─────────────────────────────────────────────

# R2 S3-compatible endpoint — format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
HX_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# Name of the R2 bucket that stores raw scrape JSON/HTML.
HX_R2_BUCKET=harvyx-raw

# R2 API token key ID (from Cloudflare dashboard → R2 → Manage API Tokens).
HX_R2_ACCESS_KEY_ID=R2_KEY_ID

# R2 API token secret that pairs with the key ID above.
HX_R2_SECRET_ACCESS_KEY=R2_KEY_SECRET


# ── SMTP EMAIL VERIFICATION ───────────────────────────────────────────────────

# From address used in the EHLO/MAIL FROM handshake during SMTP verification.
# No email is actually sent — this is only the handshake envelope sender.
HX_SMTP_VERIFY_FROM=noreply@harvics.com


# ── THIRD-PARTY ENRICHMENT APIs ───────────────────────────────────────────────

# Apollo.io API key — used for people/bulk_match and people/match enrichment.
# Dashboard: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=apollo_XXXXXXXXXXXXXXXXXXXX

# Lusha API key — used to reveal mobile phone numbers for ICP ≥ 85 contacts.
# Dashboard: https://www.lusha.com/settings/api
LUSHA_API_KEY=lusha_XXXXXXXXXXXXXXXXXXXX

# Companies House (UK) REST API key — used by the companies-house scraper.
# Register: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=00000000-0000-0000-0000-000000000000

# TinyFish search + fetch API key — used by the B2B discovery endpoint.
# Dashboard: https://tinyfish.ai/dashboard
TINYFISH_API_KEY=sk-tinyfish-XXXXXXXXXXXXXXXXXXXX


# ── AI PROVIDERS ─────────────────────────────────────────────────────────────

# Groq API key — PRIMARY AI provider for chat, generation, and transcription.
# Dashboard: https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXX

# OpenAI API key — fallback for chat, generation, transcription, and TTS.
# Dashboard: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXX

# NVIDIA NIM API key — used for deep-think (nemotron), image, video, speech.
# Dashboard: https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXX


# ── NOTIFICATIONS ─────────────────────────────────────────────────────────────

# Twilio Account SID — identifies your Twilio account for WhatsApp dispatch.
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HX_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — authenticates API calls to Twilio.
HX_TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN_HERE

# Twilio WhatsApp sender number — must be approved in Twilio WhatsApp sandbox
# or a production WhatsApp Business number. Format: whatsapp:+14155238886
HX_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Operator WhatsApp recipient — the number that receives all HarvyX alerts
# (credit warnings, sanction blocks, scrape completions). Format: whatsapp:+48XXXXXXXXX
HX_OPERATOR_WHATSAPP=whatsapp:+COUNTRY_CODE_NUMBER

# Slack incoming webhook URL — receives terminal failure and sanctions alerts.
# Create: https://api.slack.com/apps → Incoming Webhooks
HX_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX
