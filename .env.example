PORT=4000
# Internal API key for protecting AI generation endpoints
INTERNAL_API_KEY=
AI_ENGINE_URL=http://localhost:9000
MAPBOX_KEY=
GOOGLE_MAPS_KEY=
UN_COMTRADE_KEY=
OPENWEATHER_KEY=

# ─── Required in production (backend refuses to boot otherwise) ─────────
# JWT signing secret. Must be strong, unique, and not contain "fallback".
JWT_SECRET=
# Optional second secret used to sign refresh tokens. Defaults to JWT_SECRET + ':refresh'.
JWT_REFRESH_SECRET=
# Comma-separated list of allowed CORS origins. Example: https://harvics.com,https://app.harvics.com
ALLOWED_ORIGINS=

# ─── Auth tuning (optional) ─────────────────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
LOGIN_FAIL_LIMIT=5
LOGIN_FAIL_WINDOW_MS=900000

# ─── Auto-Generation Pipeline (Groq + HuggingFace + Cloudflare R2) ──────
# Already present above: GROQ_API_KEY, HF_API_KEY
# Cloudflare R2 bucket for generated images. Create in CF dashboard, then fill:
# S3-compatible endpoint (account-level, without bucket name suffix):
R2_ENDPOINT_URL=https://c606ef34847cc91452c3e27a2a7a91e6.r2.cloudflarestorage.com
R2_BUCKET_NAME=harvics-media-vault
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public CDN URL for the bucket (r2.dev public URL). Used in /api/generate response.
NEXT_PUBLIC_CDN_URL=https://pub-f2496164b9544713bde9dd18d56e3663.r2.dev
