{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "harvics-com",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
  // To enable Next.js ISR/SSG caching, create an R2 bucket and uncomment:
  // "r2_buckets": [
  //   { "binding": "NEXT_INC_CACHE_R2_BUCKET", "bucket_name": "harvics-cache" }
  // ],
  // "images": { "binding": "IMAGES" }
}
