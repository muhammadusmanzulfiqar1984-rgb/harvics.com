          "frontend": {
            "routes": ["/os/logistics/map", "/os/logistics/map/zones"],
            "components": ["WorldMapView", "LocationMarker", "RouteOptimizer", "ZoneEditor"]
          },
          "rbac": {
            "allowed_roles": ["admin", "manager", "sales", "super_admin"]
          }
        },
        {
          "id": "GPS-4",
          "name": "Geographic Analytics",
          "backend": {
            "routes": ["/api/gps/analytics"],
            "database": {
              "tables": ["geo_analytics", "geo_heatmaps"]
            },
            "endpoints": [
              "GET /api/gps/analytics/performance - Performance by region",
              "GET /api/gps/analytics/heatmap - Generate heatmap data",
              "GET /api/gps/analytics/coverage - Coverage analysis"
            ]
          },
          "frontend": {
            "routes": ["/os/logistics/analytics"],
            "components": ["GeoAnalytics", "HeatmapView", "CoverageMap"]
          },
          "rbac": {
            "allowed_roles": ["admin", "manager", "executive", "super_admin"]
          }
        }
      ],
      "acceptance_criteria": [
        "GPS tracking shows real-time vehicle locations",
        "Fleet management allows vehicle and driver assignment",
        "Digital map shows warehouses, customers, and routes",
        "Route optimization functional",
        "Geographic analytics work with territory filters",
        "Integration with Logistics and Orders modules",
        "RBAC properly restricts access"
      ]
    },
