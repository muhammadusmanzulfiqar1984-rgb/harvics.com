  ],
  "database_conventions": {
    "naming": "snake_case for tables and columns",
    "primary_keys": "TEXT id field with UUID format",
    "timestamps": "created_at, updated_at DATETIME fields",
    "foreign_keys": "Enable foreign key constraints",
    "indexes": "Index on foreign keys and frequently queried fields"
  },
  "backend_conventions": {
    "route_prefix": "/api/<domain>",
    "response_format": "{ success: boolean, data?: any, error?: string }",
    "error_handling": "Use try-catch, return proper HTTP status codes",
    "validation": "Validate all inputs, use parameterized queries",
    "logging": "Log important operations, errors, and access"
  },
  "frontend_conventions": {
    "route_structure": "/os/<domain>/<page>",
    "layout": "Use OSLegalLayout pattern for OS pages",
    "components": "Reuse existing table, form, modal components",
    "localization": "Use useTranslations hook, formatCurrency, formatDate",
    "rbac": "Use AuthGuard component with allowedRoles"
  },
  "integration_requirements": {
    "legal_with_orders": "Legal compliance check before order fulfillment",
    "import_with_inventory": "Import orders update inventory",
    "export_with_inventory": "Export orders deduct inventory",
    "gps_with_logistics": "GPS tracking integrated with shipments",
    "competitor_with_products": "Competitor products compared with ours"
  }
}

