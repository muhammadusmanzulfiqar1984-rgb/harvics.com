generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  segment       String?
  country       String?
  city          String?
  creditRating  String?
  lifetimeValue Float     @default(0)
  contactEmail  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invoices      Invoice[]
  orders        Order[]

  @@index([segment])
  @@index([country])
}

model Order {
  id              String      @id @default(cuid())
  customerId      String?
  customerName    String?
  city            String?
  channel         String?
  amount          Float       @default(0)
  currency        String      @default("USD")
  status          String      @default("Pending")
  shippingAddress String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  customer        Customer?   @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  routes          Route[]

  @@index([status])
  @@index([customerId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  sku       String
  qty       Int
  unitPrice Float  @default(0)
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model InventoryItem {
  id          String   @id @default(cuid())
  sku         String   @unique
  description String
  category    String?
  onHand      Int      @default(0)
  minStock    Int      @default(0)
  warehouse   String?
  unitCost    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([warehouse])
}

model Lead {
  id         String    @id @default(cuid())
  company    String
  contact    String?
  email      String?
  stage      String    @default("Lead")
  value      Float     @default(0)
  source     String?
  notes      String?
  aiScore    Int?
  aiTier     String?
  aiScoredAt DateTime?
  ownerId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([stage])
  @@index([aiTier])
  @@index([ownerId])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  type        String?
  status      String   @default("Active")
  budget      Float    @default(0)
  spent       Float    @default(0)
  leads       Int      @default(0)
  conversions Int      @default(0)
  startDate   String?
  endDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id         String   @id @default(cuid())
  name       String
  department String?
  position   String?
  country    String?
  city       String?
  salary     Float    @default(0)
  currency   String   @default("USD")
  status     String   @default("Active")
  joinDate   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([department])
  @@index([country])
}

model Payroll {
  id            String   @id @default(cuid())
  period        String
  totalAmount   Float    @default(0)
  currency      String   @default("USD")
  employeeCount Int      @default(0)
  status        String   @default("Pending")
  processedDate String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Invoice {
  id           String    @id @default(cuid())
  invoiceNo    String    @unique
  customerId   String?
  customerName String?
  amount       Float     @default(0)
  currency     String    @default("USD")
  status       String    @default("Unpaid")
  dueDate      String?
  type         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer? @relation(fields: [customerId], references: [id])
  payments     Payment[]

  @@index([status])
}

model Payment {
  id           String   @id @default(cuid())
  invoiceNo    String
  amount       Float    @default(0)
  currency     String   @default("USD")
  method       String?
  reference    String?
  receivedDate String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invoice      Invoice  @relation(fields: [invoiceNo], references: [invoiceNo])

  @@index([invoiceNo])
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNo     String   @unique
  description String?
  debit       String?
  credit      String?
  amount      Float    @default(0)
  currency    String   @default("USD")
  postedDate  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Route {
  id          String   @id @default(cuid())
  routeId     String   @unique
  origin      String
  destination String
  driver      String?
  vehicle     String?
  status      String   @default("Pending")
  eta         String?
  distance    Float?
  orderId     String?
  delayReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order?   @relation(fields: [orderId], references: [id])

  @@index([status])
}

model PurchaseOrder {
  id           String         @id @default(cuid())
  poNumber     String         @unique
  supplier     String
  total        Float          @default(0)
  currency     String         @default("USD")
  status       String         @default("Pending")
  expectedDate String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        PurchaseItem[]
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  sku             String
  qty             Int
  unitPrice       Float         @default(0)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model Approval {
  id              String   @id @default(cuid())
  type            String
  referenceId     String
  description     String?
  amount          Float    @default(0)
  currency        String   @default("USD")
  requestedBy     String?
  tier            String?
  status          String   @default("Pending")
  requiredRole    String?
  approvedBy      String?
  approvedAt      String?
  rejectedBy      String?
  rejectedAt      String?
  rejectionReason String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GPSRetailer {
  id           String   @id @default(cuid())
  outletName   String
  city         String?
  outletType   String?
  lat          Float?
  lng          Float?
  countryCode  String?
  monthlySales Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([countryCode])
}

model Satellite {
  id            String   @id @default(cuid())
  region        String
  type          String
  opportunity   String?
  coverageScore Float    @default(0)
  detectedAt    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TerritoryAssignment {
  id            String   @id @default(cuid())
  territoryCode String   @unique
  assignedTo    String
  region        String?
  status        String   @default("Active")
  retailers     Int      @default(0)
  coverage      Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkOrder {
  id             String    @id @default(cuid())
  workOrderNo    String    @unique
  productSku     String
  qty            Int       @default(0)
  status         String    @default("Planned")
  startDate      String?
  completionDate String?
  priority       String    @default("Normal")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bomItems       BOMItem[]

  @@index([status])
  @@index([productSku])
}

model BOMItem {
  id           String    @id @default(cuid())
  workOrderId  String
  componentSku String
  qty          Int
  unitCost     Float     @default(0)
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model QualityCheck {
  id           String    @id @default(cuid())
  checkNo      String    @unique
  workOrderId  String?
  productSku   String
  inspector    String?
  status       String    @default("Pending")
  defectsFound Int       @default(0)
  notes        String?
  inspectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([productSku])
}

model NonConformanceReport {
  id               String    @id @default(cuid())
  ncrNo            String    @unique
  qualityCheckId   String?
  severity         String    @default("Minor")
  description      String
  rootCause        String?
  correctiveAction String?
  status           String    @default("Open")
  assignedTo       String?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([severity])
}

model Project {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  status      String      @default("Active")
  priority    String      @default("Normal")
  startDate   String?
  endDate     String?
  ownerId     String?
  budget      Float       @default(0)
  spent       Float       @default(0)
  currency    String      @default("USD")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  milestones  Milestone[]
  tasks       Task[]

  @@index([status])
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  status      String    @default("Todo")
  priority    String    @default("Normal")
  assigneeId  String?
  dueDate     String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  title     String
  dueDate   String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model BankAccount {
  id           String            @id @default(cuid())
  accountNo    String            @unique
  bankName     String
  currency     String            @default("USD")
  balance      Float             @default(0)
  accountType  String            @default("Operating")
  country      String?
  status       String            @default("Active")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  transactions BankTransaction[]
}

model BankTransaction {
  id          String      @id @default(cuid())
  accountId   String
  type        String
  amount      Float
  currency    String      @default("USD")
  reference   String?
  description String?
  postedAt    DateTime    @default(now())
  createdAt   DateTime    @default(now())
  account     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([postedAt])
}

model FxRate {
  id            String   @id @default(cuid())
  fromCcy       String
  toCcy         String
  rate          Float
  effectiveDate String
  source        String?
  createdAt     DateTime @default(now())

  @@unique([fromCcy, toCcy, effectiveDate])
  @@index([effectiveDate])
}

model EmailCampaign {
  id          String    @id @default(cuid())
  name        String
  subject     String
  segment     String?
  status      String    @default("Draft")
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  clickCount  Int       @default(0)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model SocialPost {
  id          String    @id @default(cuid())
  platform    String
  content     String
  mediaUrl    String?
  status      String    @default("Draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  impressions Int       @default(0)
  engagements Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([platform])
  @@index([status])
}

model Document {
  id            String    @id @default(cuid())
  title         String
  type          String
  category      String?
  url           String?
  ownerId       String?
  partyId       String?
  status        String    @default("Draft")
  effectiveDate String?
  expiryDate    String?
  signedAt      DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type])
  @@index([status])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  channel   String    @default("in-app")
  category  String?
  title     String
  message   String
  actionUrl String?
  severity  String    @default("info")
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([read])
  @@index([category])
}

model AuditEvent {
  id        String   @id @default(cuid())
  actorId   String?
  actorRole String?
  action    String
  module    String?
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  payload   Json?
  result    String   @default("success")
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Asset {
  id             String           @id @default(cuid())
  assetCode      String           @unique
  name           String
  category       String?
  location       String?
  status         String           @default("Active")
  purchaseDate   String?
  purchasePrice  Float            @default(0)
  currency       String           @default("USD")
  warrantyExpiry String?
  ownerId        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  maintenances   MaintenanceLog[]

  @@index([status])
  @@index([category])
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  assetId     String
  type        String
  description String
  cost        Float    @default(0)
  currency    String   @default("USD")
  technician  String?
  performedAt DateTime @default(now())
  nextDueAt   String?
  createdAt   DateTime @default(now())
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([performedAt])
}

// ─── T14 SCHEMA LOCK (May 25, 2026) ─────────────────────────────────────────
// Backing models for previously demo-only endpoints in batch2-commercial,
// batch5-ops-grc, and batch67-analytics-universe. Additive only.

model DealDesk {
  id                String    @id @default(cuid())
  dealName          String
  customerId        String?
  opportunityValue  Float     @default(0)
  requestedDiscount Float     @default(0)
  requiredMargin    Float     @default(0)
  approvedDiscount  Float?
  currency          String    @default("USD")
  submittedBy       String?
  status            String    @default("Pending")
  decisionDate      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([customerId])
}

model Commission {
  id               String    @id @default(cuid())
  employeeId       String
  employeeName     String?
  period           String
  baseRevenue      Float     @default(0)
  commissionRate   Float     @default(0)
  commissionAmount Float     @default(0)
  currency         String    @default("USD")
  status           String    @default("Calculated")
  paidDate         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([employeeId])
  @@index([period])
  @@index([status])
}

model SalesForecast {
  id             String   @id @default(cuid())
  forecastPeriod String
  ownerId        String
  ownerTerritory String?
  bestCase       Float    @default(0)
  baseCase       Float    @default(0)
  worstCase      Float    @default(0)
  currency       String   @default("USD")
  confidence     Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([forecastPeriod])
  @@index([ownerId])
}

model OKR {
  id         String   @id @default(cuid())
  objective  String
  owner      String
  progress   Int      @default(0)
  keyResults Int      @default(0)
  completed  Int      @default(0)
  period     String
  status     String   @default("On Track")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([period])
  @@index([status])
}

model Incident {
  id           String    @id @default(cuid())
  title        String
  severity     String    @default("Medium")
  reportedDate DateTime  @default(now())
  status       String    @default("Open")
  resolution   String?
  resolvedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([severity])
}

// ─── GENERIC MODULE FACTORY (Session 39 · Wave 0) ───────────────────────────
// Single table that backs CRUD for every "demo" module via a uniform shape.
// Records are scoped by `moduleId` (1..71 from registry). `data` carries the
// module-specific payload as JSON so we don't need a Prisma model per module.
model GenericModuleRecord {
  id        String   @id @default(cuid())
  moduleId  Int
  status    String   @default("Active")
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  @@index([moduleId, status])
  @@index([createdAt])
}

// ─── WAVE 2 · Platform models (Session 39) ──────────────────────────────────

// Neural Governance — policies enforced at request boundary
model GovernancePolicy {
  id        String   @id @default(cuid())
  name      String
  scope     String // 'global' | 'module' | 'route'
  targetKey String? // module name or route prefix when scope != 'global'
  rule      Json // { type, params } — interpreted by middleware
  severity  String   @default("medium") // low|medium|high|critical
  enabled   Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@index([scope, targetKey])
}

model GovernanceDecision {
  id        String   @id @default(cuid())
  policyId  String
  actorId   String?
  actorRole String?
  module    String?
  route     String?
  outcome   String // allow | deny | warn
  reason    String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([policyId])
  @@index([outcome])
  @@index([createdAt])
}

// Tax Engine — rates per country/region + calc log
model TaxRate {
  id            String    @id @default(cuid())
  country       String // ISO 3166-1 alpha-2
  region        String? // state/province code
  taxType       String // VAT | GST | Sales | Excise | Withholding
  ratePercent   Float
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([country, taxType])
  @@index([effectiveFrom])
}

// Admin & Security — application users and role grants
model AppUser {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String?   @unique
  displayName String?
  role        String    @default("operator") // operator | manager | admin | superadmin
  active      Boolean   @default(true)
  lastLoginAt DateTime?
  mfaEnabled  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([role])
  @@index([active])
}

// Localisation — registered locales + per-locale toggle state
model LocaleConfig {
  id           String   @id @default(cuid())
  code         String   @unique // e.g. 'en', 'ar', 'zh-CN'
  name         String
  direction    String   @default("ltr") // ltr | rtl
  enabled      Boolean  @default(true)
  fallback     String? // fallback locale code
  numberFormat Json? // { decimal, thousand }
  dateFormat   String?
  currency     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([enabled])
}

// ─── WAVE 3 · Completing the 11 incomplete modules (Session 39) ─────────────

// #1 Financial Accounting — chart of accounts hierarchy + posting periods
model ChartAccount {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  accountType String // Asset | Liability | Equity | Revenue | Expense
  parentCode  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountType])
  @@index([parentCode])
}

model PostingPeriod {
  id        String    @id @default(cuid())
  code      String    @unique // 2026-05, 2026-Q2
  startDate DateTime
  endDate   DateTime
  status    String    @default("Open") // Open | Closed | Adjusting
  closedBy  String?
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
}

// #4 AP — Goods Receipt for 3-way match
model GoodsReceipt {
  id              String   @id @default(cuid())
  receiptNo       String   @unique
  purchaseOrderId String
  receivedDate    DateTime @default(now())
  receivedBy      String?
  qtyReceived     Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([purchaseOrderId])
}

// #8 CRM — Deal pipeline stages
model Deal {
  id            String    @id @default(cuid())
  name          String
  customerId    String?
  ownerId       String?
  stage         String    @default("Prospecting") // Prospecting|Qualified|Proposal|Negotiation|Closed Won|Closed Lost
  value         Float     @default(0)
  currency      String    @default("USD")
  probability   Int       @default(20)
  expectedClose DateTime?
  source        String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([stage])
  @@index([ownerId])
}

// #13 Procurement — RFQ workflow
model RFQ {
  id          String        @id @default(cuid())
  rfqNo       String        @unique
  title       String
  description String?
  category    String?
  dueDate     DateTime?
  status      String        @default("Draft") // Draft|Open|Closed|Awarded|Cancelled
  awardedTo   String?
  awardedAt   DateTime?
  createdBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  responses   RFQResponse[]

  @@index([status])
}

model RFQResponse {
  id           String   @id @default(cuid())
  rfqId        String
  vendorId     String
  vendorName   String?
  amount       Float    @default(0)
  currency     String   @default("USD")
  leadTimeDays Int?
  notes        String?
  status       String   @default("Submitted") // Submitted|Shortlisted|Awarded|Rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  rfq          RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([status])
}

// #14 Vendor scoring
model VendorScorecard {
  id             String   @id @default(cuid())
  vendorId       String
  vendorName     String?
  period         String // e.g. 2026-Q2
  onTimePercent  Float    @default(0)
  qualityScore   Float    @default(0) // 0-100
  priceScore     Float    @default(0) // 0-100
  responseScore  Float    @default(0) // 0-100
  overallScore   Float    @default(0)
  recommendation String   @default("Maintain") // Promote|Maintain|Warn|Drop
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([vendorId, period])
  @@index([overallScore])
}

// #22 Inventory — cycle count
model CycleCount {
  id          String   @id @default(cuid())
  sku         String
  warehouseId String?
  systemQty   Int      @default(0)
  countedQty  Int      @default(0)
  variance    Int      @default(0)
  countedBy   String?
  countedAt   DateTime @default(now())
  status      String   @default("Pending") // Pending|Confirmed|Adjusted
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sku])
  @@index([status])
}

// #26 Shipping & Freight
model Shipment {
  id             String          @id @default(cuid())
  trackingNo     String          @unique
  origin         String
  destination    String
  carrier        String?
  service        String? // air|sea|road|rail
  weightKg       Float           @default(0)
  status         String          @default("Booked") // Booked|InTransit|Delivered|Exception
  bookedAt       DateTime        @default(now())
  estimatedEta   DateTime?
  actualDelivery DateTime?
  orderId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
